/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   MÓDULOS DISPONIBLES — contexto surtiantojos
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const availableModules = [
  "dashboard", "usuarios", "roles", "categorias", "productos", "pedidos", "reportes",
]

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   DESIGN TOKENS — Surti Antojos
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const T = {
  o1: "#FF6B2B",   // Naranja primario
  o2: "#FF9A3C",   // Naranja secundario
  r1: "#E8321A",   // Rojo
  y1: "#FFCC02",   // Amarillo
  green: "#00C97A",// Verde success
  t1: "#1E1E2D",   // Texto primario
  t2: "#636578",   // Texto secundario
  t3: "#A1A3B5",   // Texto terciario
  bg: "#F5F7FA",   // Fondo
  bg2: "#FFFFFF",  // Fondo blanco
  go: "linear-gradient(135deg,#FF6B2B,#FF9A3C)",
  gr: "linear-gradient(135deg,#E8321A,#FF6B2B)",
  gy: "linear-gradient(135deg,#FF9A3C,#FFCC02)",
  border: "rgba(0,0,0,0.08)",
  border2: "rgba(255,107,43,0.22)",
  glass: "rgba(255,107,43,0.05)",
  sh: "0 4px 24px rgba(0,0,0,0.06)",
  sh2: "0 8px 40px rgba(0,0,0,0.10)",
  font: "'Plus Jakarta Sans',sans-serif",
  fontH: "'Fraunces',serif",
}

const AV_GRADS = [T.go, T.gr, T.gy,
  "linear-gradient(135deg,#FF6B2B,#FFCC02)",
  "linear-gradient(135deg,#E8321A,#FF9A3C)",
  "linear-gradient(135deg,#00C97A,#FF9A3C)"]
const avGrad = i => AV_GRADS[i % AV_GRADS.length]

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   SWAL INJECT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
if (typeof document !== "undefined" && !document.getElementById("sa-swal")) {
  const s = document.createElement("style"); s.id = "sa-swal"
  s.textContent = `
    .swal2-icon.swal2-question{border-color:#FF6B2B!important;color:#FF6B2B!important;}
    .swal2-icon.swal2-warning{border-color:#FF9A3C!important;color:#FF9A3C!important;}
    .swal2-icon.swal2-success{border-color:#00C97A!important;color:#00C97A!important;}
    .swal2-icon.swal2-success [class^=swal2-success-line]{background:#00C97A!important;}
    .swal2-icon.swal2-success .swal2-success-ring{border-color:rgba(0,201,122,.30)!important;}
    .swal2-icon.swal2-error{border-color:#E8321A!important;color:#E8321A!important;}
    .swal2-icon.swal2-error [class^=swal2-x-mark-line]{background:#E8321A!important;}
    .swal2-timer-progress-bar{background:linear-gradient(90deg,#FF6B2B,#FF9A3C)!important;}
    .swal2-container{z-index:99999!important;}
    .swal2-popup{z-index:100000!important;}
    .swal2-backdrop-show{z-index:99998!important;background:rgba(30,30,45,.28)!important;backdrop-filter:blur(2px)!important;}
  `
  document.head.appendChild(s)
}

const SW  = { customClass:{ popup:"sa-dash-pop", title:"sa-dash-ttl", htmlContainer:"sa-dash-bod", confirmButton:"sa-dash-ok", cancelButton:"sa-dash-cn" }, buttonsStyling:false }
const SWD = { ...SW }
const SWW = { ...SW }

const swalFire = (options) =>
  Swal.fire({
    ...options,
    allowOutsideClick: options.showCancelButton ? true : false,
  })

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   STYLED TABLE CELLS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

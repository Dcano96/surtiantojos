  background: T.go, color: "#fff", fontFamily: T.font,
  fontWeight: 700, fontSize: ".70rem",
  textTransform: "uppercase", letterSpacing: "1px",
  padding: "11px 14px", borderBottom: "none", whiteSpace: "nowrap", textAlign: "center",
}))

const BCell = styled(TableCell)(() => ({
  fontFamily: T.font, fontSize: ".82rem",
  padding: "9px 14px", color: T.t2,
  borderBottom: `1px solid ${T.border}`, textAlign: "center", verticalAlign: "middle",
}))

const NCell = styled(TableCell)(() => ({
  fontFamily: T.font, fontSize: ".84rem",
  padding: "9px 14px", color: T.t1,
  borderBottom: `1px solid ${T.border}`, verticalAlign: "middle",
}))

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   REUSABLE SX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const actBtnBase = {

const bView = { ...actBtnBase, background: T.go, color: "#fff" }
const bDel  = { ...actBtnBase, background: T.gr, color: "#fff" }

const btnCancel = {
  fontFamily: `${T.font} !important`, fontWeight: "600 !important",
  color: `${T.t2} !important`, borderRadius: "50px !important",
  padding: "8px 20px !important", border: `1.5px solid ${T.border} !important`,

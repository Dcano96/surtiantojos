const btnView = { ...actionBtn, background: "rgba(255, 107, 53, 0.10)", color: T.o1, "&:hover": { background: "rgba(255, 107, 53, 0.18)", transform: "translateY(-1px)", boxShadow: "0 4px 12px rgba(255,107,53,.20)" } }
const btnDel  = { ...actionBtn, background: "rgba(239, 68, 68, 0.08)", color: T.r1, "&:hover": { background: "rgba(239, 68, 68, 0.15)", transform: "translateY(-1px)", boxShadow: "0 4px 12px rgba(239,68,68,.20)" } }

